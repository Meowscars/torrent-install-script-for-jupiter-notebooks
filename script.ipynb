import libtorrent as lt
import time
ses = lt.session()
params = {'save_path': "/content/downloads/"}
link = "magnet:?xt=urn:btih:28ff3d7e5c706bf752fae3e3de58c165b438e06e&dn=Frieren.Beyond.Journeys.End.S02.1080p.CR.WEB-DL.DUAL.AAC2.0.H.264-VARYG&tr=http%3a%2f%2fnyaa.tracker.wf%3a7777%2fannounce&tr=https%3a%2f%2ftracker.nekobt.to%2fapi%2ftracker%2fpublic%2fannounce&tr=udp%3a%2f%2fopen.stealth.si%3a80%2fannounce&tr=udp%3a%2f%2ftracker.opentrackr.org%3a1337%2fannounce&tr=udp%3a%2f%2fexodus.desync.com%3a6969%2fannounce&tr=udp%3a%2f%2ftracker.torrent.eu.org%3a451%2fannounce"
handle = lt.add_magnet_uri(ses, link, params)

while not handle.has_metadata():
  time.sleep(1)
  print("Metadata grabbed. starting down")

while handle.status().state != lt.torrent_status.seeding:
  s = handle.status()
  print(f"\r{s.progress * 100:.2f}% complete (down: {s.download_rate / 1000:.1f} kb/s)", end="")
  time.sleep(5)

